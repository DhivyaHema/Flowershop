<!DOCTYPE html>
<html lang="en">
<head>
    <title>Bloom Flower Shop</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            line-height: 1.6;
            color: #333;
            background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 25%, #a8edea 50%, #fed6e3 75%, #d299c2 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 1rem 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
        }

        nav a {
            text-decoration: none;
            color: #d63384;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 10px 20px;
            border-radius: 25px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        nav a::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.5s;
        }

        nav a:hover::before {
            left: 100%;
        }

        nav a:hover {
            background: linear-gradient(45deg, #d63384, #ff69b4);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(214, 51, 132, 0.4);
        }

        .hero {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            margin: 2rem 0;
            padding: 3rem 2rem;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            text-align: center;
        }

        .hero h2 {
            font-size: 2.5rem;
            background: linear-gradient(45deg, #d63384, #ff69b4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { text-shadow: 0 0 20px rgba(214, 51, 132, 0.5); }
            to { text-shadow: 0 0 30px rgba(214, 51, 132, 0.8), 0 0 40px rgba(214, 51, 132, 0.4); }
        }

        .section {
            margin: 3rem 0;
            padding: 2rem;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            text-align: center;
        }

        .flowers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .flower-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .flower-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #d63384, #ff69b4, #d63384);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }

        .flower-card:hover::before {
            transform: scaleX(1);
        }

        .flower-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 15px;
            margin-bottom: 1rem;
            transition: transform 0.3s ease;
        }

        .flower-card:hover img {
            transform: scale(1.05);
        }

        .flower-card h3, .flower-card h4, .flower-card h5, .flower-card h6 {
            color: #d63384;
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
        }

        .price {
            font-size: 1.4rem;
            font-weight: 700;
            color: #28a745;
            background: linear-gradient(45deg, #28a745, #20c997);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .flower-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 25px 50px rgba(214, 51, 132, 0.3);
        }

        .flower-card:hover .price {
            transform: scale(1.1);
        }

        .contact-info p {
            font-size: 1.2rem;
            margin: 0.5rem 0;
        }

        .contact-info p strong {
            color: #d63384;
        }

        footer {
            background: rgba(0,0,0,0.8);
            color: white;
            text-align: center;
            padding: 2rem;
            margin-top: 3rem;
        }

        @media (max-width: 768px) {
            .hero h2 {
                font-size: 2rem;
            }
            
            nav {
                gap: 1rem;
            }
            
            nav a {
                font-size: 1rem;
                padding: 8px 15px;
            }
        }

        hr {
            border: none;
            height: 2px;
            background: linear-gradient(90deg, transparent, #d63384, transparent);
            margin: 2rem 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <center>
                <h1 style="color: #d63384; font-size: 2.5rem; margin-bottom: 1rem;">Bloom Flower Shop</h1>
                <nav>
                    <a href="#">Home</a>
                    <a href="#">Flowers</a>
                    <a href="#">About Us</a>
                    <a href="#">Contact</a>
                </nav>
            </center>
        </header>
        <hr>

        <section class="hero">
            <center>
                <h2>Fresh Flowers</h2>
                <p>Welcome to Bloom Flower Shop. We provide fresh and beautiful flowers for birthdays, weddings, and special occasions. Our flowers are fresh and arranged with care.</p>
            </center>
        </section>
        <hr>

        <section class="section about">
            <center>
                <h2>About Us</h2>
                <p>Our flower shop offers different types of flowers such as roses, tulips, and sunflowers. We always try to give the best quality flowers to our customers.</p>
            </center>
        </section>
        <hr>

        <section class="section flowers">
            <center>
                <h2>Our Flowers</h2>
            </center>
            <div class="flowers-grid">
                <div class="flower-card">
                    <img src="C:\Users\dhivy\OneDrive\Pictures\image 1.png" alt="Rose">
                    <h3>Rose</h3>
                    <p class="price">Rs. 200</p>
                    <button class="buy-now-btn" onclick="addToCart('Rose', 200)">Buy Now</button>
                </div>
                <div class="flower-card">
                    <img src="C:\Users\dhivy\OneDrive\Pictures\image 2.png" alt="Red & White Rose">
                    <h4>Red & White Rose</h4>
                    <p class="price">Rs. 250</p>
                    <button class="buy-now-btn" onclick="addToCart('Red & White Rose', 250)">Buy Now</button>
                </div>
                <div class="flower-card">
                    <img src="C:\Users\dhivy\OneDrive\Pictures\image 3.png" alt="Pink Rose">
                    <h5>Pink Rose</h5>
                    <p class="price">Rs. 350</p>
                    <button class="buy-now-btn" onclick="addToCart('Pink Rose', 350)">Buy Now</button>
                </div>
                <div class="flower-card">
                    <img src="C:\Users\dhivy\OneDrive\Pictures\image 4.png" alt="Different Roses">
                    <h6>Different Types of Roses</h6>
                    <p class="price">Rs. 400</p>
                    <button class="buy-now-btn" onclick="addToCart('Different Roses', 400)">Buy Now</button>
                </div>
            </div>
        </section>
        <hr>

        <section class="section Contact">
            <center>
                <h2>Contact</h2>
                <div class="contact-info">
                    <p><strong>Email:</strong> bloomflowers@gmail.com</p>
                    <p><strong>Phone:</strong> 9876543210</p>
                    <p><strong>Address:</strong> 123 Flower Street, Bloom City</p>
                </div>
            </center>
        </section>
    </div>

    <footer>
        <center>
            <p>&copy; 2026 Bloom Flower Shop</p>
        </center>
    </footer>
</body>
</html>
